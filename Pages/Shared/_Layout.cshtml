@* _Layout.cshtml *@

<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-MP6BQWCB0B"></script>
    <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() {
        dataLayer.push(arguments);
    }
    gtag('js', new Date());

    gtag('config', 'G-MP6BQWCB0B', {
        'send_page_view': true
    });
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kairos Technologies</title>

    @* <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" /> *@
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">


    <!-- Open Graph Protocol -->
    @using Microsoft.AspNetCore.Http.Extensions
    @{
        var siteBase = "https://www.kairostech.ca"; // your canonical host
        var path = Context.Request.Path.Value ?? "/";
        var canonicalUrl = siteBase + path;
        var ogImageUrl = siteBase + "/images/og-cover.jpg";
    }
    <meta name="description" content="Independent residential IT support in Calgary. PC troubleshooting, Wi-Fi/networking, backups, security basics, and complete system restores — remote or in-home." />
    <link rel="canonical" href="@canonicalUrl" />

    <!-- Open Graph (LinkedIn/Facebook) -->
    <meta property="og:title" content="Kairos Technologies — Residential IT Support in Calgary" />
    <meta property="og:description" content="Independent residential IT support in Calgary. PC troubleshooting, Wi-Fi networking help, backups, security basics, and complete system restores for individuals and families." />

    <!-- Geotagging for local SEO -->
    <meta name="geo.region" content="CA-AB">
    <meta name="geo.placename" content="Calgary">

    <meta property="og:type" content="website" />
    <meta property="og:url" content="@canonicalUrl" />
    <meta property="og:image" content="@ogImageUrl" />

    <!-- Open Graph image metadata that helps scapers -->
    <meta property="og:image:secure_url" content="@ogImageUrl" />
    <meta property="og:image:type" content="image/jpeg" />

    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Kairos Technologies — Residential IT Support in Calgary" />
    <meta name="twitter:description" content="PC troubleshooting, Wi-Fi/networking, backups, security basics, and complete system restores." />
    <meta name="twitter:image" content="@ogImageUrl" />
    <meta name="twitter:url" content="@canonicalUrl" />


    <!-- Structured data for Google -->
    <script type="application/ld+json">
    @Html.Raw(@"{
    ""@context"": ""https://schema.org"",
    ""@type"": ""LocalBusiness"",
    ""name"": ""Kairos Technologies"",
    ""url"": ""https://www.kairostech.ca"",
    ""email"": ""support@kairostech.ca"",
    ""areaServed"": ""Calgary, Alberta"",
    ""description"": ""Residential IT support in Calgary including PC troubleshooting, Wi-Fi networking, backups, and system restores.""
    }")
    </script>


    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ITWebsite.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary site-navbar fixed-top">
            <div class="container">
            <a class="navbar-brand d-flex align-items-center" asp-page="/Index">
                <img src="~/images/logo.png" alt="Kairos Logo" class="me-3" />
                <span class="fw-semibold fs-5">
                    Kairos Technologies
                </span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                    <li class="nav-item"><a class="nav-link" asp-page="/Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/About">About</a></li> 
                    <li class="nav-item"><a class="nav-link" asp-page="/Services">Services</a></li>                
                    @* <li class="nav-item"><a class="nav-link" asp-page="/Contact">Contact</a></li> *@
                    <li class="nav-item ms-lg-2">
                        <a class="btn btn-primary btn-sm" asp-page="/Contact">
                        Request help <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </li>
                </ul>
            </div>
            </div>
        </nav>
    </header>
    <div class="flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer bg-dark text-white-50 py-4 mt-auto border-top border-secondary">
        <div class="container">

            <!-- Row 1 : Business info -->
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="fw-semibold text-white">Kairos Technologies</div>
                    <div class="small">Reliable IT support • Remote & On-site</div>

                    <div class="small mt-2">
                        <a class="text-white-50 text-decoration-underline"
                        href="mailto:support@kairostech.ca">
                            support@kairostech.ca
                        </a>
                        <span class="mx-2">•</span>
                        Calgary, AB
                    </div>
                </div>

                <div class="col-md-6 text-md-end">
                    <div class="small text-white">
                        Built and deployed by James using ASP.NET Core and Azure.
                    </div>
                </div>
            </div>

            <!-- Row 2 : Legal -->
            <div class="row pt-3 border-top border-secondary small">
                <div class="col-md-6">
                    © @DateTime.UtcNow.Year Kairos Technologies
                </div>

                <div class="col-md-6 text-md-end">
                    <a class="text-white-50 text-decoration-underline me-3"
                    href="https://docs.google.com/forms/d/e/1FAIpQLSd1dUPUfF0eL_eJGnoisJ_huj-4FGwnukmNJ5FV432DKCc02Q/viewform?usp=header"
                    target="_blank" rel="noopener noreferrer">
                        Feedback
                    </a>

                    <a class="text-white-50 text-decoration-underline me-3"
                    asp-page="/Privacy">
                        Privacy Policy
                    </a>

                    <a class="text-white-50 text-decoration-underline"
                    asp-page="/Terms">
                        Terms of Service
                    </a>
                </div>
            </div>

        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
